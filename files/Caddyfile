{
    # Global options block
    # Optional: enables debugging globally
    debug
}

# Define a server to listen on port 80
:80 {
    # Set the root directory for the site
    root * /app

    # Enable file server to serve static files
    file_server

    # Set default page to index.html
    try_files {path} /index.html

    # Example: Reverse proxy configuration
    # Uncomment and customize if you need to proxy API requests, for example to localhost:5000
    # reverse_proxy /api/* localhost:5000
}
